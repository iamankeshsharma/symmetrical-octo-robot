{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "required": true
    },
    "Slug": {
      "type": "uid",
      "targetField": "Title"
    },
    "Excerpt": {
      "type": "text",
      "maxLength": 200
    },
    "publishedDate": {
      "type": "date"
    },
    "Content": {
      "type": "text",
      "required": true
    }
  }
}
